{
  "manifestVersion": 1,
  "id": "devops-hub-for-bluescope",
  "name": "DevOps Hub for Bluescope",
  "version": "1.0.2",
  "publisher": "MohamedYaseen",
  "description": "Developer productivity monitoring hub for Azure DevOps — tracks work items, commits, PRs and detects anomalies.",
  "categories": ["Azure Boards"],
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "icons": {
    "default": "images/icon.png"
  },
  "contributions": [
    {
      "id": "devops-hub-for-bluescope",
      "type": "ms.vss-web.hub",
      "targets": ["ms.vss-web.project-hub-group"],
      "properties": {
        "name": "DevOps Hub for Bluescope",
        "order": 100,
        "uri": "dist/index.html"
      }
    }
  ],
  "files": [
    {
      "path": "dist",
      "addressable": true
    },
    {
      "path": "images",
      "addressable": true
    }
  ],
  "scopes": [
    "vso.work",
    "vso.code",
    "vso.build"
  ]
}

